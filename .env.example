# Получить ключ можно на https://console.x.ai
XAI_API_KEY=your-xai-api-key-here

# Модель Grok (по умолчанию grok-4.5)
XAI_MODEL=grok-4.5

# Ключ WaveSpeed (Nano Banana Pro) — генерация изображений
# Получить можно на https://wavespeed.ai
WAVESPEED_API_KEY=your-wavespeed-api-key-here

# Настройки локального сервера
HOST=127.0.0.1
PORT=5000
